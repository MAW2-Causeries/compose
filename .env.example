# JWT Configuration
# generate a secure random string for JWT_SECRET, e.g., using `openssl rand -hex 32`
JWT_SECRET=your_jwt_secret_here

# Rails Configuration
# generate a secure random string for RAILS_MASTER_KEY, e.g., using `rails secret`
RAILS_MASTER_KEY=your_rails_master_key_here

# Database Configuration
# generate a secure random string for DATABASE_PASSWORD and DATABASE_ROOT_PASSWORD, e.g., using `openssl rand -hex 24`
DATABASE_PASSWORD=your_db_password_here
DATABASE_ROOT_PASSWORD=your_db_root_password_here

# Gateway Configuration
GATEWAY_PORT=8080